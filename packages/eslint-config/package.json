{
  "name": "@leogeison/eslint-config",
  "version": "0.1.0",
  "description": "Shared ESLint configs for Node.js and React projects.",
  "author": "Léo Geison",
  "license": "MIT",
  "type": "module",
  "private": false,
  "exports": {
    ".": "./dist/base.js",
    "./base": "./dist/base.js",
    "./node": "./dist/node.js",
    "./react": "./dist/react.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/base.ts src/node.ts src/react.ts --format esm --dts",
    "dev": "tsup src/base.ts src/node.ts src/react.ts --format esm --dts --watch"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
