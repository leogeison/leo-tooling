{
  "name": "@leogeison/eslint-config",
  "version": "0.1.0",
  "description": "Shared ESLint configs for Node.js and React projects.",
  "author": "Léo Geison",
  "license": "MIT",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leogeison/leo-tooling.git"
  },
  "homepage": "https://github.com/leogeison/leo-tooling",
  "bugs": {
    "url": "https://github.com/leogeison/leo-tooling/issues"
  },
  "keywords": [
    "eslint",
    "typescript",
    "react",
    "node",
    "config",
    "flat-config"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
